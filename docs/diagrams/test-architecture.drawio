        <mxCell id="x8LFrxhM3UUDlW-kx8cY-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;div&gt;&lt;b&gt;Branch / Decision:&lt;/b&gt;&amp;nbsp;test all possible paths the program can run (e.g. A &amp;amp;&amp;amp; B == T, A &amp;amp;&amp;amp; B == F)&lt;/div&gt;" vertex="1">
