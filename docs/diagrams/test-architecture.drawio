        <mxCell id="x8LFrxhM3UUDlW-kx8cY-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;div&gt;&lt;b&gt;Statements: &lt;/b&gt;lines of code&lt;/div&gt;" vertex="1">
