        <mxCell id="x8LFrxhM3UUDlW-kx8cY-28" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;div&gt;&lt;b&gt;Timing / Timeouts:&lt;/b&gt;&amp;nbsp;ensure functions stop after timeout, preventing an infinite loop&lt;/div&gt;" vertex="1">
          <mxGeometry height="99.5" width="120" x="895" y="912.5" as="geometry" />
        </mxCell>
        <mxCell id="x8LFrxhM3UUDlW-kx8cY-29" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;div&gt;&lt;b&gt;Behaviour / Mocks:&lt;/b&gt;&amp;nbsp;count function calls or verify payloads&lt;/div&gt;" vertex="1">
          <mxGeometry height="99.5" width="120" x="1034" y="912.5" as="geometry" />
        </mxCell>
        <mxCell id="x8LFrxhM3UUDlW-kx8cY-30" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;div&gt;&lt;b&gt;Modified Condition / Decision Coverage (MC/DC):&amp;nbsp; &lt;/b&gt;a method of making a group of test cases that will verify how each sub-condition affects the full condition without needing a full truth table for every possible combination&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;To create the list of test cases, f&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;or each sub-condition, write two test cases: one where that sub-condition is true and one where that sub-condition is false. Choose the value of the other sub-conditions such that the final condition only changes when the focused sub-condition changes.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Creates n + 1 test cases where n is the number of sub-conditions.&lt;/div&gt;" vertex="1">
          <mxGeometry height="364" width="303" x="181" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="x8LFrxhM3UUDlW-kx8cY-31" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;" value="Test code coverage using &lt;b&gt;unit tests&lt;/b&gt;" vertex="1">
